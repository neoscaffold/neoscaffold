<header class="ns">
  <div id="logo">
    <LinkTo @route="index" class="index active ember-view">
      <img src="/assets/neoscaffold-typeface.webp" alt="NeoScaffold">
    </LinkTo>
  </div>
  <LinkTo @route="workflow">
    <nav aria-label="workflows">
      <span class="i">Create NeoScaffold Workflows</span>
      <i class="fa-solid fa-diagram-project fa" aria-hidden="true"></i>
      <span class="nlbl">Editor</span>
    </nav>
  </LinkTo>
  <LinkTo @route="catalog">
    <nav aria-label="catalog">
      <span class="i">Browse the NeoScaffold Catalog</span>
      <i class="fa-solid fa-list-tree fa" aria-hidden="true"></i>
      <span class="nlbl">Catalog</span>
    </nav>
  </LinkTo>
  <div id="preferences">
    {{!-- <div id="search">
      <form>
        <div class="atf sb">
          <i id="srchi" class="fa-solid fa-search fa" aria-hidden="true"></i>
          <input id="search-text" placeholder="Search..." class="ember-text-field ember-view" type="text">
        </div>
      </form>
    </div> --}}
    {{#if this.authEnabled}}
      {{#if this.session.isAuthenticated}}
        <div id="account">
          <div class="signout">
            {{!-- template-lint-disable require-presentational-children --}}
            <div role="button" {{on "click" this.signOut}}>
              <span class="i">Sign out of your account.</span>
              <i class="fa-solid fa-sign-out fa" aria-hidden="true"></i>
              <span class="nlbl">Sign Out</span>
            </div>
          </div>
        </div>
      {{else}}
        <div id="account">
          <div>
            <LinkTo @route="sign-in" class="ember-view">
              <span class="i">Sign in to your account.</span>
              <i class="fa-solid fa-sign-in fa" aria-hidden="true"></i>
              <span class="nlbl">Sign In</span>
            </LinkTo>
          </div>
          <div>
            <LinkTo @route="sign-up" class="ember-view">
              <span class="i">Sign up for an account today.</span>
              <i class="fa-solid fa-user-plus fa" aria-hidden="true"></i>
              <span class="nlbl">Sign Up</span>
            </LinkTo>
          </div>
        </div>
      {{/if}}
    {{/if}}
  </div>
</header>